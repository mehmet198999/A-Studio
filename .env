# Domain Warming - Umgebungsvariablen
# Kopieren als .env und anpassen

# Admin-Passwort für das Web-Dashboard
ADMIN_PASSWORD=admin123

# API-Authentifizierungstoken (beliebiger sicherer String)
AUTH_TOKEN=warming-secret-token

# Datenbank (automatisch via Docker Compose gesetzt)
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres/warming

# Redis (automatisch via Docker Compose gesetzt)
# REDIS_URL=redis://redis:6379/0
